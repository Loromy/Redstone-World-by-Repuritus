{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "fallback": {
      "type": "model",
      "model": "item/book"
    },
    "cases": [
      {
        "when": "book_1",
        "model": {
          "type": "model",
          "model": "item/deko/books_1"
        }
      },
      {
        "when": "book_2",
        "model": {
          "type": "model",
          "model": "item/deko/books_2"
        }
      }
    ]
  }
}