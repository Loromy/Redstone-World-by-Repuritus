{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "fallback": {
      "type": "model",
      "model": "item/gold_ingot"
    },
    "cases": [
      {
        "when": "purple_amulett",
        "model": {
          "type": "model",
          "model": "item/amulett/purple_amulett"
        }
      },
      {
        "when": "elytra_ring",
        "model": {
          "type": "model",
          "model": "item/elytra_parkour/elytra_ring"
        }
      }
    ]
  }
}