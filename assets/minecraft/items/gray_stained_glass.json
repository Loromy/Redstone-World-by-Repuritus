{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "fallback": {
      "type": "model",
      "model": "block/gray_stained_glass"
    },
    "cases": [
      {
        "when": "space_helmet_open",
        "model": {
          "type": "model",
          "model": "item/red_station/space_suit/space_helmet_open"
        }
      },
      {
        "when": "space_helmet_closed",
        "model": {
          "type": "model",
          "model": "item/red_station/space_suit/space_helmet_closed"
        }
      }
    ]
  }
}